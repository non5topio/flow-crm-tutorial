{
    "enabled": "true",
    "increase-coverage": {
      "project-name": "flow-crm-tutorial",
      "target-branches": [
        "v24"
      ],
      "test-env-docker-stage": "test",
      "build-test-env-docker-stage-script-path": "tool/build-test-env-docker-stage.sh",
      "test-files-folders": [
        "src/test"
      ],
      "source-test-file-paths": [
        {
          "source-file-path": "app/src/main/java/com/example/application/views/list/ContactForm.java",
          "test-file-path": "app/src/test/java/com/example/application/views/list/ContactFormTest.java"
        }
      ],
      "test-command": "redis-server --daemonize yes && mvn test -DskipFrontend=true -Dvaadin.skip.devserver=true -Dvaadin.productionMode=true -Dtest='!*E2E*'",
      "coverage-type": "jacoco",
      "code-coverage-report-path": "target/site/jacoco/jacoco.xml",
      "desired-coverage": 90,
      "max-iterations": 1,
      "max-number-of-test-cases": 6
    }
}